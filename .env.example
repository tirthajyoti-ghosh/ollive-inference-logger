# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Database
POSTGRES_PASSWORD=ollive_dev
DATABASE_URL=postgresql+asyncpg://ollive:ollive_dev@postgres:5432/ollive

# Redis
REDIS_URL=redis://redis:6379

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# SDK (used by backend internally)
OLLIVE_INGEST_ENDPOINT=http://backend:8000/api/v1/ingest

# PII Redaction
PII_REDACTION_ENABLED=true
PII_REDACTION_LEVEL=standard
